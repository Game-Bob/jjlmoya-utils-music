---
import type { KnownLocale } from '../../types';
import type { AudioStorageCalculatorUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as AudioStorageCalculatorUI;
---

<div
  class="asc"
  id="asc-root"
  data-label-duration-set={t.labelDurationSet ?? 'Configured duration: {time}'}
  data-label-recording-possible={t.labelRecordingPossible ?? 'Recording possible with {gb} GB configured'}
  data-label-duration={t.labelDuration ?? 'Recording Duration'}
  data-label-space-available={t.labelSpaceAvailable ?? 'Available Space'}
  data-toggle-label-space={t.toggleLabelSpace ?? 'Calculate how much I can record with my free space'}
  data-toggle-label-time={t.toggleLabelTime ?? 'Back to duration calculation'}
  data-copy-done={t.copyDone ?? 'Summary Copied!'}
  data-summary-space={t.summarySpace ?? 'The {t} recording at {bits}-bit/{hz} in {channels} mode will take approximately {result}.'}
  data-summary-time={t.summaryTime ?? 'With {space} GB available, you can record up to {result} of audio at {bits}-bit/{hz} {channels}.'}
>
  <div class="asc__config-grid">
    <div class="asc__card asc__card--accent">
      <span class="asc__label">{t.labelConfig}</span>
      <div class="asc__presets">
        <button class="asc__preset-btn" data-hz="44100" data-bits="16" data-channels="2">CD</button>
        <button class="asc__preset-btn asc__preset-btn--active" data-hz="48000" data-bits="24" data-channels="2">Radio/Video</button>
        <button class="asc__preset-btn" data-hz="96000" data-bits="24" data-channels="2">Studio Pro</button>
        <button class="asc__preset-btn" data-hz="48000" data-bits="32" data-channels="1">Podcast</button>
      </div>

      <div class="asc__field">
        <label class="asc__label" for="hz-select">{t.labelHz}</label>
        <select id="hz-select" class="asc__select">
          <option value="44100">{t.optHz44100}</option>
          <option value="48000" selected>{t.optHz48000}</option>
          <option value="88200">{t.optHz88200}</option>
          <option value="96000">{t.optHz96000}</option>
          <option value="192000">{t.optHz192000}</option>
        </select>
      </div>

      <div class="asc__field">
        <label class="asc__label" for="bits-select">{t.labelBits}</label>
        <select id="bits-select" class="asc__select">
          <option value="16">{t.optBits16}</option>
          <option value="24" selected>{t.optBits24}</option>
          <option value="32">{t.optBits32}</option>
        </select>
      </div>

      <div class="asc__field">
        <label class="asc__label" for="channels-select">{t.labelChannels}</label>
        <select id="channels-select" class="asc__select">
          <option value="1">{t.optCh1}</option>
          <option value="2" selected>{t.optCh2}</option>
          <option value="6">{t.optCh6}</option>
          <option value="8">{t.optCh8}</option>
        </select>
      </div>
    </div>

    <div class="asc__card">
      <span class="asc__label" id="time-input-label">{t.labelDuration}</span>
      <div class="asc__time-inputs" id="duration-inputs">
        <div class="asc__time-box">
          <label class="asc__label" for="time-h">{t.labelHours}</label>
          <input type="number" id="time-h" class="asc__input" value="1" min="0" placeholder="00" />
        </div>
        <div class="asc__time-box">
          <label class="asc__label" for="time-m">{t.labelMinutes}</label>
          <input type="number" id="time-m" class="asc__input" value="0" min="0" max="59" placeholder="00" />
        </div>
        <div class="asc__time-box">
          <label class="asc__label" for="time-s">{t.labelSeconds}</label>
          <input type="number" id="time-s" class="asc__input" value="0" min="0" max="59" placeholder="00" />
        </div>
      </div>

      <div class="asc__field" id="space-box" style="display:none;">
        <label class="asc__label" for="space-input">{t.labelCapacity}</label>
        <div class="asc__space-row">
          <input type="number" id="space-input" class="asc__input" value="1" min="0.01" step="0.1" />
          <span class="asc__label">GB</span>
        </div>
      </div>

      <div class="asc__card-divider"></div>

      <div class="asc__mode-toggle" id="toggle-mode">
        <div class="asc__toggle-pill"></div>
        <span class="asc__toggle-text" id="toggle-text">{t.toggleLabelSpace}</span>
      </div>
    </div>
  </div>

  <div class="asc__results">
    <div class="asc__hero">
      <div class="asc__main-result" id="result-primary">0.00 MB</div>
      <div class="asc__secondary-result" id="result-secondary"></div>
    </div>

    <div class="asc__card">
      <span class="asc__label">{t.labelComparison}</span>
      <div class="asc__comparison">
        <table class="asc__table">
          <thead>
            <tr>
              <th>{t.thFormat}</th>
              <th>{t.thQuality}</th>
              <th>{t.thSize}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><span class="asc__format-tag">WAV / AIFF</span></td>
              <td>{t.qualityWav}</td>
              <td id="comp-wav">-</td>
            </tr>
            <tr>
              <td><span class="asc__format-tag">FLAC</span></td>
              <td>{t.qualityFlac}</td>
              <td id="comp-flac">-</td>
            </tr>
            <tr>
              <td><span class="asc__format-tag">MP3 (320kbps)</span></td>
              <td>{t.qualityMp3High}</td>
              <td id="comp-mp3-320">-</td>
            </tr>
            <tr>
              <td><span class="asc__format-tag">MP3 (128kbps)</span></td>
              <td>{t.qualityMp3Std}</td>
              <td id="comp-mp3-128">-</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="asc__capacity">
      <span class="asc__label">{t.labelDevices}</span>
      <div class="asc__bars">
        <div class="asc__bar-item">
          <div class="asc__bar-label"><span>{t.device32}</span> <span id="bar-pct-32">0%</span></div>
          <div class="asc__bar-track"><div class="asc__bar-fill" id="bar-fill-32"></div></div>
        </div>
        <div class="asc__bar-item">
          <div class="asc__bar-label"><span>{t.device128}</span> <span id="bar-pct-128">0%</span></div>
          <div class="asc__bar-track"><div class="asc__bar-fill" id="bar-fill-128"></div></div>
        </div>
        <div class="asc__bar-item">
          <div class="asc__bar-label"><span>{t.device1tb}</span> <span id="bar-pct-1024">0%</span></div>
          <div class="asc__bar-track"><div class="asc__bar-fill" id="bar-fill-1024"></div></div>
        </div>
      </div>
    </div>

    <div class="asc__actions">
      <button class="asc__copy-btn" id="copy-summary">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        <span id="copy-btn-text">{t.btnCopy}</span>
      </button>
    </div>
  </div>
</div>


<script>
  const root = document.getElementById('asc-root') as HTMLElement;
  const ds = root?.dataset ?? {};

  const LABEL_DURATION_SET = ds.labelDurationSet ?? 'Configured duration: {time}';
  const LABEL_RECORDING_POSSIBLE = ds.labelRecordingPossible ?? 'Recording possible with {gb} GB configured';
  const LABEL_DURATION = ds.labelDuration ?? 'Recording Duration';
  const LABEL_SPACE_AVAILABLE = ds.labelSpaceAvailable ?? 'Available Space';
  const TOGGLE_LABEL_SPACE = ds.toggleLabelSpace ?? 'Calculate how much I can record with my free space';
  const TOGGLE_LABEL_TIME = ds.toggleLabelTime ?? 'Back to duration calculation';
  const COPY_DONE = ds.copyDone ?? 'Summary Copied!';
  const SUMMARY_SPACE = ds.summarySpace ?? 'The {t} recording at {bits}-bit/{hz} in {channels} mode will take approximately {result}.';
  const SUMMARY_TIME = ds.summaryTime ?? 'With {space} GB available, you can record up to {result} of audio at {bits}-bit/{hz} {channels}.';

  let calculationMode = 'space';

  function formatSize(bytes: number): string {
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
    if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
  }

  function formatTime(seconds: number): string {
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.floor(seconds % 60);
    return `${h}h ${String(m).padStart(2, '0')}m ${String(s).padStart(2, '0')}s`;
  }

  function getSelectVal(id: string): number {
    return parseInt((document.getElementById(id) as HTMLSelectElement).value);
  }

  function calculate(): void {
    const hz = getSelectVal('hz-select');
    const bits = getSelectVal('bits-select');
    const channels = getSelectVal('channels-select');
    const resPrimary = document.getElementById('result-primary');
    const resSecondary = document.getElementById('result-secondary');
    if (!resPrimary || !resSecondary) return;

    const bytesPerSecond = (hz * bits * channels) / 8;

    if (calculationMode === 'space') {
      const h = parseInt((document.getElementById('time-h') as HTMLInputElement).value) || 0;
      const m = parseInt((document.getElementById('time-m') as HTMLInputElement).value) || 0;
      const s = parseInt((document.getElementById('time-s') as HTMLInputElement).value) || 0;
      const totalSeconds = h * 3600 + m * 60 + s;
      const totalBytes = bytesPerSecond * totalSeconds;
      resPrimary.textContent = formatSize(totalBytes);
      resSecondary.textContent = LABEL_DURATION_SET.replace('{time}', formatTime(totalSeconds));
      updateComparison(totalBytes);
      updateBars(totalBytes);
    } else {
      const availableGb = parseFloat((document.getElementById('space-input') as HTMLInputElement).value) || 0;
      const availableBytes = availableGb * 1024 * 1024 * 1024;
      const totalSeconds = availableBytes / bytesPerSecond;
      resPrimary.textContent = formatTime(totalSeconds);
      resSecondary.textContent = LABEL_RECORDING_POSSIBLE.replace('{gb}', String(availableGb));
      updateComparison(availableBytes);
      updateBars(availableBytes);
    }
  }

  function updateComparison(wavBytes: number): void {
    const wavEl = document.getElementById('comp-wav');
    const flacEl = document.getElementById('comp-flac');
    const mp3HiEl = document.getElementById('comp-mp3-320');
    const mp3LoEl = document.getElementById('comp-mp3-128');
    if (wavEl) wavEl.textContent = formatSize(wavBytes);
    if (flacEl) flacEl.textContent = formatSize(wavBytes * 0.55) + ' (est.)';

    const hz = getSelectVal('hz-select');
    const bits = getSelectVal('bits-select');
    const channels = getSelectVal('channels-select');
    const bps = (hz * bits * channels) / 8;
    const secs = wavBytes / bps;
    if (mp3HiEl) mp3HiEl.textContent = formatSize((320000 / 8) * secs);
    if (mp3LoEl) mp3LoEl.textContent = formatSize((128000 / 8) * secs);
  }

  function updateBars(totalBytes: number): void {
    const devices = [
      { id: '32', cap: 32 * 1024 * 1024 * 1024 },
      { id: '128', cap: 128 * 1024 * 1024 * 1024 },
      { id: '1024', cap: 1024 * 1024 * 1024 * 1024 },
    ];
    devices.forEach((dev) => {
      const pct = Math.min(100, (totalBytes / dev.cap) * 100);
      const fill = document.getElementById(`bar-fill-${dev.id}`);
      const text = document.getElementById(`bar-pct-${dev.id}`);
      if (!fill || !text) return;
      fill.style.width = `${pct}%`;
      text.textContent = `${pct.toFixed(pct < 1 ? 2 : 1)}%`;
      fill.classList.remove('asc__bar-fill--warning', 'asc__bar-fill--danger');
      if (pct > 90) fill.classList.add('asc__bar-fill--danger');
      else if (pct > 70) fill.classList.add('asc__bar-fill--warning');
    });
  }

  function setupPresets(): void {
    document.querySelectorAll('.asc__preset-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.asc__preset-btn').forEach((p) => p.classList.remove('asc__preset-btn--active'));
        btn.classList.add('asc__preset-btn--active');
        (document.getElementById('hz-select') as HTMLSelectElement).value = btn.getAttribute('data-hz') ?? '48000';
        (document.getElementById('bits-select') as HTMLSelectElement).value = btn.getAttribute('data-bits') ?? '24';
        (document.getElementById('channels-select') as HTMLSelectElement).value = btn.getAttribute('data-channels') ?? '2';
        calculate();
      });
    });
  }

  function setElDisplay(id: string, display: string): void {
    const el = document.getElementById(id);
    if (el) el.style.display = display;
  }

  function setElText(id: string, text: string): void {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  function applyToggleUI(isSpace: boolean): void {
    setElDisplay('duration-inputs', isSpace ? 'grid' : 'none');
    setElDisplay('space-box', isSpace ? 'none' : 'block');
    setElText('time-input-label', isSpace ? LABEL_DURATION : LABEL_SPACE_AVAILABLE);
    setElText('toggle-text', isSpace ? TOGGLE_LABEL_SPACE : TOGGLE_LABEL_TIME);
  }

  function setupToggle(): void {
    const toggle = document.getElementById('toggle-mode');
    toggle?.addEventListener('click', () => {
      calculationMode = calculationMode === 'space' ? 'time' : 'space';
      toggle.classList.toggle('asc__mode-toggle--active');
      applyToggleUI(calculationMode === 'space');
      calculate();
    });
  }

  function buildSummaryText(bits: string, hz: string, channels: string, primary: string): string {
    if (calculationMode === 'space') {
      const h = (document.getElementById('time-h') as HTMLInputElement).value;
      const m = (document.getElementById('time-m') as HTMLInputElement).value;
      return SUMMARY_SPACE.replace('{t}', `${h}h ${m}m`).replace('{bits}', bits)
        .replace('{hz}', hz).replace('{channels}', channels).replace('{result}', primary);
    }
    const space = (document.getElementById('space-input') as HTMLInputElement).value;
    return SUMMARY_TIME.replace('{space}', space).replace('{result}', primary)
      .replace('{bits}', bits).replace('{hz}', hz).replace('{channels}', channels);
  }

  function flashCopyBtn(btn: HTMLElement): void {
    const btnText = document.getElementById('copy-btn-text');
    const originalText = btnText?.textContent ?? '';
    btn.classList.add('asc__copy-btn--done');
    if (btnText) btnText.textContent = COPY_DONE;
    setTimeout(() => {
      btn.classList.remove('asc__copy-btn--done');
      if (btnText) btnText.textContent = originalText;
    }, 2000);
  }

  function setupCopy(): void {
    document.getElementById('copy-summary')?.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLElement;
      const hzEl = document.getElementById('hz-select') as HTMLSelectElement;
      const hz = hzEl.options[hzEl.selectedIndex]?.text.split(' ')[0] ?? '';
      const bits = String(getSelectVal('bits-select'));
      const chEl = document.getElementById('channels-select') as HTMLSelectElement;
      const channels = chEl.options[chEl.selectedIndex]?.text.split(' ')[0] ?? '';
      const primary = document.getElementById('result-primary')?.textContent ?? '';
      const text = buildSummaryText(bits, hz, channels, primary);
      navigator.clipboard.writeText(text).then(() => flashCopyBtn(btn));
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    ['hz-select', 'bits-select', 'channels-select', 'time-h', 'time-m', 'time-s', 'space-input'].forEach((id) => {
      document.getElementById(id)?.addEventListener('input', calculate);
    });
    setupPresets();
    setupToggle();
    setupCopy();
    calculate();
  });
</script>
