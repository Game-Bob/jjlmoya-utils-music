---
import type { KnownLocale } from '../../types';
import type { FrequencyNoteConverterUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as FrequencyNoteConverterUI;
const noteOptions = (t.noteOptions ?? 'C,C#,D,D#,E,F,F#,G,G#,A,A#,B').split('|');
---

<div
  class="fnc-root"
  id="fnc-root"
  data-note-names={t.noteNames ?? 'C,C#,D,D#,E,F,F#,G,G#,A,A#,B'}
  data-unit-hz-exact={t.unitHzExact ?? 'exact Hz'}
  data-tuned={t.tuned ?? 'Tuned'}
  data-sharp={t.sharp ?? 'sharp'}
  data-flat={t.flat ?? 'flat'}
  data-piano-octave={t.pianoOctave ?? 'Oct'}
  data-copy-feedback={t.copyFeedback ?? 'Copied!'}
  data-history-load-aria={t.historyLoadAria ?? 'Load %s Hz'}
>
  <div class="fnc__mode-switcher" role="group">
    <button class="fnc__mode-btn fnc__mode-btn--active" id="btn-hz-to-note">{t.btnHzToNote}</button>
    <button class="fnc__mode-btn" id="btn-note-to-hz">{t.btnNoteToHz}</button>
  </div>

  <div class="fnc__calibration-bar">
    <div class="fnc__cal-main">
      <span class="fnc__cal-label">{t.labelRef}</span>
      <div class="fnc__cal-presets">
        <button class="fnc__cal-preset fnc__cal-preset--active" data-ref="440">440 Hz</button>
        <button class="fnc__cal-preset" data-ref="432">432 Hz</button>
        <button class="fnc__cal-preset" data-ref="444">444 Hz</button>
      </div>
      <input
        type="number"
        id="ref-input"
        class="fnc__cal-custom"
        value="440"
        min="400"
        max="480"
        step="0.5"
        aria-label={t.ariaRefCustom}
      />
      <span class="fnc__cal-unit">Hz</span>
    </div>
    <p class="fnc__cal-info" set:html={t.calInfo} />
  </div>

  <div class="fnc__main-panel" id="panel-hz-to-note">
    <div class="fnc__input-zone">
      <label for="hz-input" class="fnc__input-label">{t.labelFrequency}</label>
      <div class="fnc__input-row">
        <input
          type="number"
          id="hz-input"
          class="fnc__big-input"
          value="440"
          min="16"
          max="20000"
          step="0.01"
          inputmode="decimal"
          aria-label={t.ariaFreqInput}
        />
        <span class="fnc__big-unit">Hz</span>
        <button class="fnc__play-btn" id="play-btn-hz" aria-label={t.ariaPlay}>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </button>
      </div>
    </div>

    <div class="fnc__result-hero" aria-live="polite">
      <div class="fnc__note-name" id="hz-result-note">A4</div>
      <div class="fnc__note-freq" id="hz-result-exact">440.00 Hz</div>
      <button class="fnc__copy-hero" id="copy-note-name" data-value="A4">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        {t.copyNoteName}
      </button>
    </div>

    <div class="fnc__tuner">
      <div class="fnc__tuner-track">
        <div class="fnc__tuner-center-mark"></div>
        <div class="fnc__tuner-needle" id="tuner-needle"></div>
      </div>
      <div class="fnc__tuner-labels">
        <span>-50</span><span>-25</span>
        <span class="fnc__tuner-label-center">0</span>
        <span>+25</span><span>+50</span>
      </div>
      <div class="fnc__cents-value" id="cents-display">0.0 cents</div>
    </div>

    <div class="fnc__harmonics">
      <div class="fnc__harmonic-card">
        <span class="fnc__harmonic-label">{t.labelOctaveDown}</span>
        <span class="fnc__harmonic-value" id="harmonic-down-val">220.00 Hz</span>
        <button class="fnc__copy-small" data-copy-target="harmonic-down-val">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
      <div class="fnc__harmonic-card fnc__harmonic-card--main">
        <span class="fnc__harmonic-label">{t.labelInputFreq}</span>
        <span class="fnc__harmonic-value" id="harmonic-main-val">440.00 Hz</span>
        <button class="fnc__copy-small" data-copy-target="harmonic-main-val">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
      <div class="fnc__harmonic-card">
        <span class="fnc__harmonic-label">{t.labelOctaveUp}</span>
        <span class="fnc__harmonic-value" id="harmonic-up-val">880.00 Hz</span>
        <button class="fnc__copy-small" data-copy-target="harmonic-up-val">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="fnc__main-panel fnc__main-panel--hidden" id="panel-note-to-hz">
    <div class="fnc__note-selector">
      <label class="fnc__select-label" for="note-text-input">{t.labelNoteInput}</label>
      <input
        type="text"
        id="note-text-input"
        class="fnc__text-input"
        placeholder={t.placeholderNote}
      />
      <div class="fnc__note-dropdowns">
        <div class="fnc__select-group">
          <label class="fnc__select-label" for="note-select">{t.labelSetNote}</label>
          <select id="note-select" class="fnc__select">
            {noteOptions.map((opt, i) => <option value={String(i)}>{opt}</option>)}
          </select>
        </div>
        <div class="fnc__select-group">
          <label class="fnc__select-label" for="octave-select">{t.labelSetOctave}</label>
          <select id="octave-select" class="fnc__select">
            {[0,1,2,3,4,5,6,7,8].map((o) => <option value={String(o)} selected={o === 4}>{o}</option>)}
          </select>
        </div>
      </div>
    </div>

    <div class="fnc__result-hero" aria-live="polite">
      <div class="fnc__note-name" id="note-result-hz">440.00</div>
      <div class="fnc__note-freq">Hz</div>
      <button class="fnc__copy-hero" id="copy-hz-value" data-value="440.00">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        {t.copyHz}
      </button>
    </div>

    <div class="fnc__harmonics">
      <div class="fnc__harmonic-card">
        <span class="fnc__harmonic-label">{t.labelOctaveDown}</span>
        <span class="fnc__harmonic-value" id="n2h-harmonic-down">220.00 Hz</span>
        <button class="fnc__copy-small" data-copy-target="n2h-harmonic-down">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
      <div class="fnc__harmonic-card fnc__harmonic-card--main">
        <span class="fnc__harmonic-label">{t.labelSelectedNote}</span>
        <span class="fnc__harmonic-value" id="n2h-harmonic-main">440.00 Hz</span>
        <button class="fnc__copy-small" data-copy-target="n2h-harmonic-main">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
      <div class="fnc__harmonic-card">
        <span class="fnc__harmonic-label">{t.labelOctaveUp}</span>
        <span class="fnc__harmonic-value" id="n2h-harmonic-up">880.00 Hz</span>
        <button class="fnc__copy-small" data-copy-target="n2h-harmonic-up">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
    </div>

    <div class="fnc__play-row">
      <button class="fnc__play-full-btn" id="play-btn-note">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        {t.btnListenNote}
      </button>
    </div>
  </div>

  <div class="fnc__piano-section">
    <div class="fnc__piano-label">{t.pianoLabel}</div>
    <div class="fnc__piano" id="piano" role="group" aria-label={t.pianoAria}></div>
  </div>

  <div class="fnc__history-section">
    <div class="fnc__history-header">
      <span class="fnc__history-title">{t.historyTitle}</span>
      <button class="fnc__history-clear" id="clear-history">{t.historyClear}</button>
    </div>
    <ul class="fnc__history-list" id="history-list" role="list"></ul>
    <div class="fnc__history-empty" id="history-empty">{t.historyEmpty}</div>
  </div>
</div>


<style is:global>
  .fnc__mode-switcher {
    display: flex;
    background: var(--fnc-bg-panel);
    border-radius: 14px;
    padding: 5px;
    gap: 5px;
    border: 1px solid var(--fnc-border);
    align-self: center;
  }

  .fnc__mode-btn {
    flex: 1;
    padding: 0.65rem 1.75rem;
    border-radius: 10px;
    border: none;
    background: transparent;
    color: var(--fnc-mode-inactive);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .fnc__mode-btn--active {
    background: linear-gradient(135deg, var(--fnc-purple), var(--fnc-violet));
    color: #fff;
    box-shadow: 0 4px 20px rgba(192, 38, 211, 0.4);
  }

  .fnc__mode-btn:not(.fnc__mode-btn--active):hover {
    color: var(--fnc-fuchsia);
    background: rgba(192, 38, 211, 0.08);
  }

  .fnc__calibration-bar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--fnc-bg-panel);
    padding: 1.1rem 1.4rem;
    border-radius: 18px;
    border: 1px solid var(--fnc-border-cyan);
  }

  .fnc__cal-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .fnc__cal-info {
    font-size: 0.78rem;
    color: var(--fnc-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .fnc__cal-info strong { color: var(--fnc-cyan); }

  .fnc__cal-label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fnc-cyan);
    white-space: nowrap;
  }

  .fnc__cal-presets { display: flex; gap: 0.5rem; }

  .fnc__cal-preset {
    background: transparent;
    border: 1px solid var(--fnc-border-cyan);
    color: var(--fnc-text-muted);
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .fnc__cal-preset--active {
    background: rgba(6, 182, 212, 0.15);
    border-color: var(--fnc-cyan);
    color: var(--fnc-cyan);
  }

  .fnc__cal-preset:not(.fnc__cal-preset--active):hover {
    border-color: var(--fnc-cyan);
    color: var(--fnc-cyan);
  }

  .fnc__cal-custom {
    width: 80px;
    background: var(--fnc-bg);
    border: 1px solid var(--fnc-border);
    border-radius: 8px;
    padding: 0.3rem 0.6rem;
    color: var(--fnc-text);
    font-size: 0.85rem;
    font-weight: 700;
    text-align: center;
  }

  .fnc__cal-custom:focus {
    outline: none;
    border-color: var(--fnc-cyan);
  }

  .fnc__cal-unit {
    font-size: 0.78rem;
    color: var(--fnc-text-dim);
    font-weight: 600;
  }

  .fnc__main-panel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .fnc__main-panel--hidden { display: none; }

  .fnc__input-zone {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .fnc__input-label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fnc-purple);
  }

  .fnc__input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .fnc__big-input {
    flex: 1;
    background: var(--fnc-bg-input);
    border: 2px solid var(--fnc-border-purple);
    border-radius: 14px;
    padding: 1.1rem 1.4rem;
    color: var(--fnc-text);
    font-size: 2rem;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    transition: all 0.3s ease;
    -webkit-appearance: none;
    -moz-appearance: textfield;
    appearance: none;
  }

  .fnc__big-input::-webkit-outer-spin-button,
  .fnc__big-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  .fnc__big-input:focus {
    outline: none;
    border-color: var(--fnc-purple);
    background: var(--fnc-bg-input-focus);
    box-shadow: 0 0 0 4px rgba(192, 38, 211, 0.12);
  }

  .fnc__big-unit {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--fnc-text-dim);
  }

  .fnc__play-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--fnc-purple), var(--fnc-violet));
    border: none;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
    box-shadow: 0 4px 20px rgba(192, 38, 211, 0.4);
  }

  .fnc__play-btn:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(192, 38, 211, 0.55); }
  .fnc__play-btn:active { transform: scale(0.95); }

  .fnc__result-hero {
    text-align: center;
    padding: 2rem;
    background: var(--fnc-bg-panel);
    border-radius: 20px;
    border: 1px solid var(--fnc-border-purple);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .fnc__note-name {
    font-size: 4rem;
    font-weight: 900;
    color: var(--fnc-fuchsia);
    line-height: 1;
    letter-spacing: -0.02em;
    text-shadow: 0 0 40px rgba(192, 38, 211, 0.4);
  }

  .fnc__note-freq {
    font-size: 0.95rem;
    color: var(--fnc-text-muted);
    font-weight: 500;
  }

  .fnc__copy-hero {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(192, 38, 211, 0.1);
    border: 1px solid var(--fnc-border-purple);
    color: var(--fnc-fuchsia);
    padding: 0.5rem 1.2rem;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 0.5rem;
  }

  .fnc__copy-hero:hover { background: rgba(192, 38, 211, 0.2); transform: translateY(-1px); }

  .fnc__copy-hero--done {
    background: rgba(16, 185, 129, 0.15);
    border-color: var(--fnc-green);
    color: var(--fnc-green);
  }

  .fnc__tuner {
    background: var(--fnc-bg-panel);
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--fnc-border);
  }

  .fnc__tuner-track {
    position: relative;
    height: 8px;
    background: var(--fnc-tuner-track);
    border-radius: 99px;
    margin-bottom: 0.5rem;
  }

  .fnc__tuner-center-mark {
    position: absolute;
    top: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 16px;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 1px;
  }

  .fnc__tuner-needle {
    position: absolute;
    top: -6px;
    left: 50%;
    width: 4px;
    height: 20px;
    border-radius: 2px;
    background: var(--fnc-purple);
    transform: translateX(-50%);
    transition: left 0.15s ease, background 0.2s;
    box-shadow: 0 0 8px rgba(192, 38, 211, 0.8);
  }

  .fnc__tuner-needle--perfect { background: var(--fnc-green); box-shadow: 0 0 12px rgba(16, 185, 129, 0.9); }
  .fnc__tuner-needle--sharp { background: var(--fnc-amber); box-shadow: 0 0 8px rgba(245, 158, 11, 0.8); }
  .fnc__tuner-needle--flat { background: var(--fnc-cyan); box-shadow: 0 0 8px rgba(6, 182, 212, 0.8); }

  .fnc__tuner-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    color: var(--fnc-text-dim);
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-top: 0.35rem;
  }

  .fnc__tuner-label-center { color: var(--fnc-green); }

  .fnc__cents-value {
    text-align: center;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--fnc-text-muted);
    margin-top: 0.5rem;
    letter-spacing: 0.04em;
  }

  .fnc__harmonics {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    gap: 0.85rem;
  }

  .fnc__harmonic-card {
    background: var(--fnc-bg-panel);
    border-radius: 14px;
    padding: 1rem;
    border: 1px solid var(--fnc-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-align: center;
    transition: border-color 0.2s;
  }

  .fnc__harmonic-card--main { border-color: var(--fnc-border-purple); }

  .fnc__harmonic-label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fnc-text-dim);
  }

  .fnc__harmonic-value {
    font-size: 1rem;
    font-weight: 800;
    color: var(--fnc-text);
    font-variant-numeric: tabular-nums;
  }

  .fnc__copy-small {
    background: transparent;
    border: 1px solid var(--fnc-border);
    color: var(--fnc-text-dim);
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .fnc__copy-small:hover {
    border-color: var(--fnc-purple);
    color: var(--fnc-fuchsia);
    background: rgba(192, 38, 211, 0.1);
  }

  .fnc__copy-small--done {
    border-color: var(--fnc-green);
    color: var(--fnc-green);
    background: rgba(16, 185, 129, 0.1);
  }

  .fnc__note-selector {
    background: var(--fnc-bg-panel);
    border-radius: 16px;
    padding: 1.25rem;
    border: 1px solid var(--fnc-border-purple);
  }

  .fnc__note-dropdowns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .fnc__select-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .fnc__select-label {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fnc-purple);
  }

  .fnc__select {
    background: var(--fnc-bg);
    border: 1.5px solid var(--fnc-border-purple);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    color: var(--fnc-text);
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    -webkit-appearance: none;
