---
import type { KnownLocale } from '../../types';
import type { BpmCalculatorUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as BpmCalculatorUI;
---

<div class="bpm-root">
  <header class="bpm-header">
    <div class="bpm-field">
      <label for="bpm-input" class="bpm-label">{t.labelTempo}</label>
      <input
        type="number"
        id="bpm-input"
        class="bpm-input"
        value="120"
        min="30"
        max="999"
        step="0.1"
        aria-label={t.labelTempo}
      />
    </div>
    <button id="bpm-tap-btn" class="bpm-tap-btn" title={t.btnTap}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z" />
      </svg>
      {t.btnTap}
    </button>
  </header>

  <div class="bpm-sections">
    <section class="bpm-card">
      <h2 class="bpm-card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 10-6 6"/><path d="m16 10-4 4"/><path d="m12 10-2 2"/><path d="M7 21a2.82 2.82 0 0 1-4-4l14-14a2.82 2.82 0 0 1 4 4z"/></svg>
        {t.sectionDelay}
      </h2>
      <div class="bpm-table-wrap">
        <table class="bpm-table">
          <thead>
            <tr>
              <th class="bpm-th">{t.colNote}</th>
              <th class="bpm-th">{t.colMs}</th>
              <th class="bpm-th">{t.colHz}</th>
              <th class="bpm-th"></th>
            </tr>
          </thead>
          <tbody id="bpm-simple-body"></tbody>
        </table>
      </div>
    </section>

    <section class="bpm-card">
      <h2 class="bpm-card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="1"/></svg>
        {t.sectionDotted}
      </h2>
      <div class="bpm-table-wrap">
        <table class="bpm-table">
          <thead>
            <tr>
              <th class="bpm-th">{t.colNote}</th>
              <th class="bpm-th">{t.colMs}</th>
              <th class="bpm-th">{t.colHz}</th>
              <th class="bpm-th"></th>
            </tr>
          </thead>
          <tbody id="bpm-dotted-body"></tbody>
        </table>
      </div>
    </section>

    <section class="bpm-card">
      <h2 class="bpm-card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 13V5c0-1.1.9-2 2-2h14a2 2 0 0 1 2 2v8"/><path d="M3 21h18"/><path d="M7 11v10"/><path d="M11 11v10"/><path d="M15 11v10"/><path d="M19 11v10"/></svg>
        {t.sectionTriplets}
      </h2>
      <div class="bpm-table-wrap">
        <table class="bpm-table">
          <thead>
            <tr>
              <th class="bpm-th">{t.colNote}</th>
              <th class="bpm-th">{t.colMs}</th>
              <th class="bpm-th">{t.colHz}</th>
              <th class="bpm-th"></th>
            </tr>
          </thead>
          <tbody id="bpm-triplet-body"></tbody>
        </table>
      </div>
    </section>

    <section class="bpm-card bpm-extra-card">
      <h2 class="bpm-card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15V6"/><path d="M18.5 18a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/><path d="M12 12H3"/><path d="M16 6H3"/><path d="M12 18H3"/></svg>
        {t.sectionReverb}
      </h2>
      <p class="bpm-info" set:html={t.infoPreDelay} />
      <div class="bpm-predelay-grid" id="bpm-predelay-container"></div>
    </section>
  </div>
</div>



<script define:vars={{ ariaMs: t.copyAriaMs, ariaPreDelay: t.copyAriaPreDelay, copyFeedback: t.copyFeedback }}>
  const bpmInput = document.getElementById('bpm-input');
  const tapBtn = document.getElementById('bpm-tap-btn');
  const simpleBody = document.getElementById('bpm-simple-body');
  const dottedBody = document.getElementById('bpm-dotted-body');
  const tripletBody = document.getElementById('bpm-triplet-body');
  const preDelayContainer = document.getElementById('bpm-predelay-container');

  let tapTimes = [];

  const NOTE_SUBDIVISIONS = [
    { name: '1/1', factor: 4 },
    { name: '1/2', factor: 2 },
    { name: '1/4', factor: 1 },
    { name: '1/8', factor: 0.5 },
    { name: '1/16', factor: 0.25 },
    { name: '1/32', factor: 0.125 },
    { name: '1/64', factor: 0.0625 },
  ];

  const PRE_DELAY_SUBDIVISIONS = [
    { name: '1/64', factor: 0.0625 },
    { name: '1/128', factor: 0.03125 },
    { name: '1/256', factor: 0.015625 },
  ];

  const SVG_COPY = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';

  function makeCopyBtn(value, label, feedback) {
    return `<button class="bpm-copy" data-value="${value}" aria-label="${label}" data-copy-feedback="${feedback}">${SVG_COPY}</button>`;
  }

  function getBpm() {
    const raw = parseFloat(bpmInput?.value ?? '120');
    const bpm = isNaN(raw) || raw < 1 ? 120 : raw;
    return Math.min(bpm, 999);
  }

  function createRow(name, ms, hz) {
    const tr = document.createElement('tr');
    tr.className = 'bpm-row';
    tr.innerHTML = `
      <td class="bpm-td bpm-note-name">${name}</td>
      <td class="bpm-td bpm-ms-value">${ms.toFixed(2)}</td>
      <td class="bpm-td bpm-hz-value">${hz.toFixed(2)}</td>
      <td class="bpm-td">${makeCopyBtn(ms.toFixed(2), ariaMs, copyFeedback)}</td>
    `;
    return tr;
  }

  function updateTable(tbody, subdivisions, baseMs, modifier) {
    tbody.innerHTML = '';
    for (const sub of subdivisions) {
      const ms = baseMs * sub.factor * modifier;
      tbody.appendChild(createRow(sub.name, ms, 1000 / ms));
    }
  }

  function updatePreDelay(baseMs) {
    if (!preDelayContainer) return;
    preDelayContainer.innerHTML = '';
    for (const sub of PRE_DELAY_SUBDIVISIONS) {
      const ms = baseMs * sub.factor;
      const div = document.createElement('div');
      div.className = 'bpm-predelay-card';
      div.innerHTML = `
        <div class="bpm-predelay-info">
          <span class="bpm-predelay-type">${sub.name}</span>
          <span class="bpm-predelay-ms">${ms.toFixed(2)}</span>
        </div>
        ${makeCopyBtn(ms.toFixed(2), ariaPreDelay, copyFeedback)}
      `;
      preDelayContainer.appendChild(div);
    }
  }

  function calculateValues() {
    const baseMs = 60000 / getBpm();
    if (simpleBody) updateTable(simpleBody, NOTE_SUBDIVISIONS, baseMs, 1);
    if (dottedBody) updateTable(dottedBody, NOTE_SUBDIVISIONS, baseMs, 1.5);
    if (tripletBody) updateTable(tripletBody, NOTE_SUBDIVISIONS, baseMs, 2 / 3);
    updatePreDelay(baseMs);
  }

  function handleTap() {
    if (!bpmInput || !tapBtn) return;
    const now = Date.now();
    tapTimes.push(now);
    if (tapTimes.length > 5) tapTimes.shift();

    if (tapTimes.length > 1) {
      const diffs = [];
      for (let i = 1; i < tapTimes.length; i++) {
        diffs.push(tapTimes[i] - tapTimes[i - 1]);
      }
      const avg = diffs.reduce((a, b) => a + b) / diffs.length;
      bpmInput.value = (60000 / avg).toFixed(1);
      calculateValues();
    }

    tapBtn.classList.add('bpm-tap-active');
    setTimeout(() => tapBtn?.classList.remove('bpm-tap-active'), 100);
  }

  bpmInput?.addEventListener('input', calculateValues);
  tapBtn?.addEventListener('click', handleTap);

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.bpm-copy');
    if (!btn) return;
    const val = btn.getAttribute('data-value');
    if (!val) return;
    navigator.clipboard.writeText(val).then(() => {
      btn.classList.add('bpm-copy-success');
      setTimeout(() => btn.classList.remove('bpm-copy-success'), 2000);
    });
  });

  setInterval(() => {
    if (tapTimes.length > 0 && Date.now() - tapTimes[tapTimes.length - 1] > 3000) {
      tapTimes = [];
    }
  }, 1000);

  calculateValues();
</script>
